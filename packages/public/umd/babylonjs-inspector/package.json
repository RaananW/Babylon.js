{
    "name": "babylonjs-inspector-legacy",
    "version": "9.0.0",
    "private": true,
    "main": "babylon.inspector.bundle.js",
    "types": "babylon.inspector.module.d.ts",
    "files": [
        "*"
    ],
    "scripts": {
        "build": "npm run clean && npm run build:prod && npm run build:declaration",
        "build:dev": "webpack --env development",
        "build:prod": "webpack --env production",
        "build:declaration": "build-tools -c pud --config ./config.json",
        "clean": "rimraf dist && rimraf babylon*.* -g"
    },
    "dependencies": {
        "babylonjs": "9.0.0",
        "babylonjs-addons": "9.0.0",
        "babylonjs-gui": "9.0.0",
        "babylonjs-gui-editor": "9.0.0",
        "babylonjs-loaders": "9.0.0",
        "babylonjs-materials": "9.0.0",
        "babylonjs-serializers": "9.0.0"
    },
    "devDependencies": {
        "@dev/addons": "1.0.0",
        "@dev/build-tools": "1.0.0",
        "@dev/inspector-legacy": "1.0.0",
        "@dev/shared-ui-components": "1.0.0",
        "@types/react": "18.3.28",
        "@types/react-dom": "18.3.7",
        "css-loader": "7.1.4",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "sass-loader": "16.0.7",
        "source-map-loader": "4.0.2",
        "ts-loader": "9.5.4",
        "webpack": "5.105.4",
        "webpack-cli": "6.0.1",
        "webpack-merge": "5.10.0"
    },
    "keywords": [
        "3D",
        "javascript",
        "html5",
        "webgl",
        "babylon.js"
    ],
    "license": "Apache-2.0",
    "sideEffects": true,
    "homepage": "https://www.babylonjs.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/BabylonJS/Babylon.js.git"
    },
    "bugs": {
        "url": "https://github.com/BabylonJS/Babylon.js/issues"
    }
}
