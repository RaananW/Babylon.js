{
    "name": "@tools/playground",
    "private": true,
    "version": "1.0.0",
    "scripts": {
        "build": "webpack",
        "build:declaration": "build-tools -c pud --config ./config.json",
        "build:deployment": "npm run clean && webpack --env mode=production",
        "typecheck": "tsc -p tsconfig.build.json --noEmit",
        "serve": "webpack serve",
        "serve:prod": "webpack serve --env mode=production",
        "serve:https": "webpack serve --env mode=development --server-type https --host ::",
        "serve:dev": "webpack serve --env mode=development --env watch=all",
        "clean": "rimraf dist"
    },
    "devDependencies": {
        "@dev/build-tools": "1.0.0",
        "@dev/core": "1.0.0",
        "@tools/snippet-loader": "1.0.0",
        "@pmmmwh/react-refresh-webpack-plugin": "0.6.0",
        "@svgr/webpack": "7.0.0",
        "@types/react": "18.3.28",
        "@types/react-dom": "18.3.7",
        "@types/uuid": "10.0.0",
        "@typescript/ata": "0.9.8",
        "copy-webpack-plugin": "14.0.0",
        "css-loader": "7.1.4",
        "es-module-lexer": "2.0.0",
        "file-loader": "6.2.0",
        "html-webpack-plugin": "5.6.6",
        "mini-css-extract-plugin": "2.6.1",
        "monaco-editor": "0.55.1",
        "monaco-editor-webpack-plugin": "7.1.1",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-refresh": "0.17.0",
        "react-refresh-typescript": "2.0.11",
        "sass-loader": "16.0.7",
        "style-loader": "3.3.4",
        "url-loader": "4.1.1",
        "webpack": "5.105.4",
        "webpack-cli": "6.0.1",
        "webpack-merge": "5.10.0"
    },
    "sideEffects": true
}
