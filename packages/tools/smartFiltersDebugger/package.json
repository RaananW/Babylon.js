{
    "name": "@tools/smart-filters-debugger",
    "private": true,
    "version": "0.1.0",
    "description": "A browser extension to allow for debugging Babylon.js Smart Filters in websites",
    "license": "MIT",
    "readme": "README.md",
    "sideEffects": false,
    "files": [
        "dist",
        "src",
        "license.md",
        "readme.md"
    ],
    "scripts": {
        "clean": "rimraf dist && rimraf tsconfig.build.tsbuildinfo",
        "build": "npm run clean && npm run compile",
        "compile": "webpack --env=prod",
        "watch": "webpack --env=dev --watch"
    },
    "devDependencies": {
        "@fortawesome/fontawesome-svg-core": "6.7.2",
        "@fortawesome/free-solid-svg-icons": "6.7.2",
        "@fortawesome/react-fontawesome": "0.2.6",
        "@types/chrome": "0.0.268",
        "@types/react": "18.3.28",
        "@types/react-dom": "18.3.7",
        "copy-webpack-plugin": "14.0.0",
        "css-loader": "7.1.4",
        "file-loader": "6.2.0",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "sass": "1.98.0",
        "sass-loader": "16.0.7",
        "source-map-loader": "4.0.2",
        "style-loader": "3.3.4",
        "ts-loader": "9.5.4",
        "url-loader": "4.1.1",
        "webpack": "5.105.4",
        "webpack-cli": "6.0.1",
        "webpack-dev-server": "5.2.2",
        "@tools/smart-filters-editor-control": "^1.0.0"
    }
}
