{
    "name": "@tools/flow-graph-editor",
    "private": true,
    "version": "1.0.0",
    "files": [
        "dist"
    ],
    "types": "dist/index.d.ts",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "scripts": {
        "build": "npm run clean && npm run compile",
        "build:declaration": "build-tools -c pud --config ./config.json",
        "build:deployment": "npm run clean && webpack --env mode=production",
        "compile": "tsc -b tsconfig.build.json",
        "postcompile": "build-tools -c pa",
        "serve": "webpack serve",
        "serve:prod": "webpack serve --env mode=production",
        "serve:https": "webpack serve --env mode=development --server-type https --host ::",
        "serve:dev": "webpack serve --env mode=development --env watch=all",
        "test:e2e": "playwright test -c ../../../playwright.config.ts --project=flowGraphEditor",
        "test:e2e:ui": "playwright test -c ../../../playwright.config.ts --project=flowGraphEditor --ui",
        "clean": "rimraf dist && rimraf *.tsbuildinfo -g"
    },
    "dependencies": {
        "react": "18.3.1",
        "react-dom": "18.3.1"
    },
    "devDependencies": {
        "@dev/build-tools": "1.0.0",
        "@dev/core": "1.0.0",
        "@dev/shared-ui-components": "1.0.0",
        "@tools/snippet-loader": "1.0.0",
        "@svgr/webpack": "7.0.0",
        "@types/react": "18.3.28",
        "@types/react-dom": "18.3.7",
        "copy-webpack-plugin": "14.0.0",
        "css-loader": "7.1.4",
        "html-webpack-plugin": "5.6.6",
        "mini-css-extract-plugin": "2.6.1",
        "sass-loader": "16.0.7",
        "split.js": "1.6.5",
        "style-loader": "3.3.4",
        "webpack": "5.105.4",
        "webpack-cli": "6.0.1",
        "webpack-merge": "5.10.0"
    },
    "sideEffects": true
}
